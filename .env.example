# Copy this file to .env and fill in your real keys.
# .env is in .gitignore so your credentials are never committed.

# Alpaca brokerage — free account at alpaca.markets
# Use "Paper Trading" keys for paper mode, "Live Trading" keys for real money.
ALPACA_API_KEY=YOUR_ALPACA_API_KEY
ALPACA_SECRET_KEY=YOUR_ALPACA_SECRET_KEY

# NewsAPI — free account at newsapi.org (1000 requests/day)
NEWS_API_KEY=YOUR_NEWSAPI_KEY

# Set to "false" to enable real-money trading (default: paper)
PAPER_TRADING=true
